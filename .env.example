# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/agarbattikart

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (buyer payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# RazorpayX (optional — seller payouts). If unset, payouts are processed manually by an admin.
RAZORPAYX_ACCOUNT_NUMBER=

# Default admin (used by seed script)
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@agarbattikart.com
ADMIN_PASSWORD=Admin@123
